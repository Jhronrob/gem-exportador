{
  "name": "gem-exportador-jest-tests",
  "version": "1.0.0",
  "description": "Testes unitários Jest para validação da lógica de fila e itens presos do gem-exportador",
  "type": "module",
  "scripts": {
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:verbose": "node --experimental-vm-modules node_modules/jest/bin/jest.js --verbose"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {},
    "testMatch": [
      "**/*.test.mjs"
    ]
  },
  "devDependencies": {
    "jest": "^29.7.0"
  }
}
